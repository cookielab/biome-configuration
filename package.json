{
	"name": "@cookielab.io/biome-config",
	"version": "1.2.0",
	"description": "Biome rulesets for various project types.",
	"files": [
		"dist"
	],
	"exports": {
		"./base": "./dist/base.json",
		"./frontend": "./dist/frontend.json",
		"./react": "./dist/react.json",
		"./next": "./dist/next.json",
		"./node": "./dist/node.json",
		"./graphql": "./dist/graphql.json"
	},
	"main": "./dist/base.json",
	"keywords": [
		"biome",
		"biome-config"
	],
	"packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc",
	"type": "module",
	"repository": {
		"url": "https://github.com/cookielab/biome-configuration"
	},
	"scripts": {
		"build": "tsx script/build --target ./dist",
		"generate": "tsx script/generateSchema --source ./node_modules/@biomejs/biome/configuration_schema.json --target ./src/generated/configuration.ts",
		"doc": "typedoc",
		"lint": "biome check",
		"format": "biome format --write",
		"types": "tsc",
		"release": "pnpm types && pnpm build && pnpm lint && commit-and-tag-version"
	},
	"peerDependencies": {
		"@biomejs/biome": ">=2.3.14"
	},
	"devDependencies": {
		"@commitlint/cli": "20.4.1",
		"@commitlint/config-conventional": "20.4.1",
		"@commitlint/types": "20.4.0",
		"@types/node": "25.2.3",
		"commit-and-tag-version": "12.6.1",
		"conventional-changelog-conventionalcommits": "9.1.0",
		"json-schema-to-typescript": "15.0.4",
		"ts-to-zod": "5.1.0",
		"tsx": "4.21.0",
		"typedoc": "0.28.16",
		"typedoc-plugin-markdown": "4.10.0",
		"typescript": "5.9.3",
		"zod": "4.3.6"
	}
}
